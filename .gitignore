# Step2 remote experiment archives: keep lightweight, AI-readable artifacts;
# exclude binary weights, trajectory arrays, split indexes, and per-graph dumps.
surrogate_experiment_results/Step2/**/remote_results/**
!surrogate_experiment_results/Step2/**/remote_results/**/
!surrogate_experiment_results/Step2/**/remote_results/**/run_config.json
!surrogate_experiment_results/Step2/**/remote_results/**/metrics/test_summary.csv
