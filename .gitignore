# Decision-analysis artifacts are intentionally trackable so GitHub-hosted AI
# tools can inspect the report, scripts, figures, logs, and curated result CSVs.
!surrogate_experiment_results/decision_analysis/
!surrogate_experiment_results/decision_analysis/**
surrogate_experiment_results/decision_analysis/scripts/__pycache__/
surrogate_experiment_results/decision_analysis/scripts/__pycache__/**
surrogate_experiment_results/decision_analysis/results/edge_error_criticality.csv

# Papers and image artifacts are intentionally trackable so GitHub-hosted AI
# tools can inspect generated reports and figures.
surrogate_experiment_results/plot_results_step1bc/combined_step1bc_per_graph.csv

# SPO paper shortest-path validation artifacts are intentionally small and
# useful for advisor / expert-AI diagnosis.
!surrogate_experiment_results/SPO_validation/paper_shortest_path/results/
!surrogate_experiment_results/SPO_validation/paper_shortest_path/results/**

# Step2 experiment outputs:
# - Track curated root-level summary tables, figures, and README files for AI review.
# - Keep remote run archives local by default.
# - Never track per-graph detail dumps; generate smaller summaries/figures from them.
!surrogate_experiment_results/Step2/*summary*.csv
!surrogate_experiment_results/Step2/*summary*.json
surrogate_experiment_results/Step2/**/remote_results/**
!surrogate_experiment_results/Step2/**/remote_results/**/
!surrogate_experiment_results/Step2/**/remote_results/**/plots/
!surrogate_experiment_results/Step2/**/remote_results/**/plots/**
surrogate_experiment_results/Step2/**/*per_graph*.csv
surrogate_experiment_results/Step2/**/*per_graph*.json

# Third-party dependencies
generator_webapp/bower_components/

# Generated scripts / temporary files
combined-kidney.js
*.tmp
