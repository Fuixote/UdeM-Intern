# Runtime configuration for CIRRELT garnet.
# Source this from the repository root before running experiments:
#   source configs/runtime/garnet.env

module load anaconda/2023-07.2
module load gurobi/13.0.0

conda activate KEPs

export KEP_REPO_ROOT="/local1/fuweik/UdeM-Intern"
export KEP_PYTHON="${HOME}/.conda/envs/KEPs/bin/python"
export KEP_DATA_DIR="${KEP_REPO_ROOT}/dataset/processed"
export KEP_RESULTS_DIR="${KEP_REPO_ROOT}/results"
export KEP_SOLUTIONS_DIR="${KEP_REPO_ROOT}/solutions"

export OMP_NUM_THREADS="${OMP_NUM_THREADS:-4}"
export MKL_NUM_THREADS="${MKL_NUM_THREADS:-4}"
export OPENBLAS_NUM_THREADS="${OPENBLAS_NUM_THREADS:-4}"

mkdir -p "${KEP_DATA_DIR}" "${KEP_RESULTS_DIR}" "${KEP_SOLUTIONS_DIR}"
